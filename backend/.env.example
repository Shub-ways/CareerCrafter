# Backend Configuration Environment Variables

# API Keys
GEMINI_API_KEY=your_google_gemini_api_key_here

# SMTP Email Configuration (For OTPs and Peer Matching)
# Default values use Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Set this to the brand new Gmail address you created (e.g., careercrafter.app@gmail.com)
SMTP_USER=your_new_email@gmail.com

# Set this to the 16-character App Password generated in Google Security Settings (No spaces!)
SMTP_PASS=your_16_char_app_password

# The email address that users will see it's from (Leave same as SMTP_USER)
SMTP_FROM_EMAIL=your_new_email@gmail.com
